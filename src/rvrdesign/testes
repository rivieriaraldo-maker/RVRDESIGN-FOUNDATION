import React, { useState, useMemo } from 'react';
import { RVRButton, RVRCard, RVRGrid } from './rvrdesign/components';

/* ============================================================================
 * ComparadorVeiculosSelector.jsx
 * RVR e-Mobil — Seleção de Veículo A × Veículo B pelo Consultor
 *
 * Uso dentro do PortalRVR.jsx:
 *   import ComparadorVeiculosSelector from './ComparadorVeiculosSelector';
 *   <ComparadorVeiculosSelector />
 *
 * Não altera nenhum estado do PortalRVR. Comunica exclusivamente via
 * window.RVR_EVENTS.publish('ui:change_module', ...) — contrato já homologado.
 *
 * ── RVRDESIGN FOUNDATION — PILOTO HOMOLOGADO (v3) ──────────────────────────
 * RVRCard / RVRGrid / RVRButton (Component Library) + Tokens integrais.
 * Ressalvas aplicadas nesta versão:
 *  - Zero style inline para cor. `.cvs-accent-label` é uma classe LOCAL
 *    deste componente (não é um utilitário novo da Foundation) que só lê
 *    var(--rvr-accent) — não existe ainda um `.rvr-text-accent` oficial em
 *    rvr-typography.css; se for útil em outros componentes, isso deveria
 *    virar um registro RVRDESIGN formal, não uma decisão deste piloto.
 *  - DM Mono (`.rvr-text-data`) mantido para dados técnicos/IDs/informação
 *    de veículo (bloco "selecionado"). Inter (`.rvr-input`) só nos <select>,
 *    por serem elementos de formulário.
 * Zero alteração de lógica, props, hooks, state, eventos ou payloads.
 * ========================================================================== */

const CSS = `
.cvs-accent-label{ color: var(--rvr-accent); }
.cvs-slot{
  background:var(--rvr-bg-secondary);
  border:1px solid var(--rvr-border);
  border-radius:6px;
  padding:10px 12px;
}
.cvs-select{width:100%;cursor:pointer;}
.cvs-select--model{margin-top:6px;}
.cvs-warn-wrap{text-align:center;margin-top:var(--rvr-space-sm);}
`;

function agruparPorMarca(veiculos) {
  var grupos = {};
  veiculos.forEach(function (v) {
    if (!grupos[v.marca]) grupos[v.marca] = [];
    grupos[v.marca].push(v);
  });
  return grupos;
}

function carregarCatalogo() {
  try {
    if (window.CATALOGO_MESTRE && typeof window.CATALOGO_MESTRE.getAll === 'function') {
      return window.CATALOGO_MESTRE.getAll();
    }
  } catch (err) {
    console.error('[ComparadorVeiculosSelector] falha ao carregar catálogo', err);
  }
  return [];
}

export default function ComparadorVeiculosSelector() {
  var catalogo = useMemo(carregarCatalogo, []);
  var grupos = useMemo(function () { return agruparPorMarca(catalogo); }, [catalogo]);
  var marcas = useMemo(function () { return Object.keys(grupos).sort(); }, [grupos]);

  var [marcaA, setMarcaA] = useState('');
  var [idA, setIdA] = useState('');
  var [marcaB, setMarcaB] = useState('');
  var [idB, setIdB] = useState('');

  var veiculosA = marcaA ? (grupos[marcaA] || []) : [];
  var veiculosB = marcaB ? (grupos[marcaB] || []) : [];

  var veiculoA = catalogo.find(function (v) { return v.id === idA; }) || null;
  var veiculoB = catalogo.find(function (v) { return v.id === idB; }) || null;

  var prontoPraComparar = !!(idA && idB && idA !== idB);

  function iniciarComparacao() {
    if (!prontoPraComparar) return;
    try {
      if (!window.RVR_EVENTS || typeof window.RVR_EVENTS.publish !== 'function') {
        console.error('[ComparadorVeiculosSelector] window.RVR_EVENTS indisponível.');
        return;
      }
      window.RVR_EVENTS.publish('ui:change_module', {
        target: 'IOCRVR',
        triggeredBy: 'COMPARADOR_VEICULOS_SELECTOR',
        timestamp: new Date().toISOString(),
        context: {
          idVeiculoA: idA,
          idVeiculoB: idB,
          dadosVeiculo: { marca: veiculoA.marca, modelo: veiculoA.modelo }
        }
      });
    } catch (err) {
      console.error('[ComparadorVeiculosSelector] falha ao publicar evento', err);
    }
  }

  return (
    <>
      <style>{CSS}</style>
      <RVRCard
        header={
          <span className="rvr-text-caption cvs-accent-label">
            IOC Comparativo — Selecionar Veículos
          </span>
        }
      >
        <RVRGrid columns={2}>
          {/* VEÍCULO A */}
          <div className="cvs-slot">
            <span className="rvr-text-caption cvs-accent-label" style={{ display: 'block', marginBottom: 6 }}>
              Veículo A (Eletrificado)
            </span>
            <select className="cvs-select rvr-input rvr-focus-ring" value={marcaA}
              onChange={function (e) { setMarcaA(e.target.value); setIdA(''); }}>
              <option value="">Marca...</option>
              {marcas.map(function (m) { return <option key={m} value={m}>{m}</option>; })}
            </select>
            {marcaA && (
              <select className="cvs-select cvs-select--model rvr-input rvr-focus-ring" value={idA}
                onChange={function (e) { setIdA(e.target.value); }}>
                <option value="">Modelo...</option>
                {veiculosA.map(function (v) {
                  return <option key={v.id} value={v.id}>{v.modelo} {v.versao || ''}</option>;
                })}
              </select>
            )}
            {/* Dados técnicos / ID do veículo — DM Mono (rvr-text-data), não Inter */}
            <div className="rvr-text-data rvr-text-secondary" style={{ marginTop: 5, minHeight: 14 }}>
              {veiculoA ? <><strong className="rvr-text-primary">{veiculoA.marca} {veiculoA.modelo}</strong> · {veiculoA.id}</> : '—'}
            </div>
          </div>

          {/* VEÍCULO B */}
          <div className="cvs-slot">
            <span className="rvr-text-caption cvs-accent-label" style={{ display: 'block', marginBottom: 6 }}>
              Veículo B (Referência)
            </span>
            <select className="cvs-select rvr-input rvr-focus-ring" value={marcaB}
              onChange={function (e) { setMarcaB(e.target.value); setIdB(''); }}>
              <option value="">Marca...</option>
              {marcas.map(function (m) { return <option key={m} value={m}>{m}</option>; })}
            </select>
            {marcaB && (
              <select className="cvs-select cvs-select--model rvr-input rvr-focus-ring" value={idB}
                onChange={function (e) { setIdB(e.target.value); }}>
                <option value="">Modelo...</option>
                {veiculosB.map(function (v) {
                  return <option key={v.id} value={v.id}>{v.modelo} {v.versao || ''}</option>;
                })}
              </select>
            )}
            <div className="rvr-text-data rvr-text-secondary" style={{ marginTop: 5, minHeight: 14 }}>
              {veiculoB ? <><strong className="rvr-text-primary">{veiculoB.marca} {veiculoB.modelo}</strong> · {veiculoB.id}</> : '—'}
            </div>
          </div>
        </RVRGrid>

        <div style={{ marginTop: 10 }}>
          <RVRButton disabled={!prontoPraComparar} onClick={iniciarComparacao} style={{ width: '100%' }}>
            {prontoPraComparar ? '⚡ Iniciar IOC Comparativo' : 'Selecione os dois veículos'}
          </RVRButton>
        </div>

        {idA && idB && idA === idB && (
          <div className="cvs-warn-wrap">
            <p className="rvr-text-body-sm rvr-text-secondary">
              Veículo A e B são o mesmo modelo. Selecione modelos diferentes.
            </p>
          </div>
        )}
      </RVRCard>
    </>
  );
}
